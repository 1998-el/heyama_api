# ============================================
# BACKBLAZE B2 - Configuration S3
# ============================================

# Application Key ID (24 caractères, commence par 00...)
B2_ACCESS_KEY_ID=

# Application Key (secrète)
B2_SECRET_ACCESS_KEY=

# Nom du bucket B2
B2_BUCKET_NAME=

# Endpoint S3 de la région du bucket
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# URL publique de base du bucket (sert à dériver la clé de l'objet)
B2_PUBLIC_URL=https://f005.backblazeb2.com/file/<BUCKET>

# Région B2
B2_REGION=us-east-005

# ============================================
# APPLICATION
# ============================================
PORT=5000
SOCKET_PORT=3001

# ============================================
# MONGODB
# ============================================
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# ============================================
# CORS / front
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
